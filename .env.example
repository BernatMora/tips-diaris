# Clau de l'API d'OpenRouter
# Obté-la a: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Model a usar (opcional, per defecte: anthropic/claude-haiku-4-5)
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# Claus VAPID per a les notificacions push
# Genera-les executant: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:el-teu-email@exemple.com
